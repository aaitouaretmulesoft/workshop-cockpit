generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Credential {
  id                   Int       @id @default(autoincrement())
  username             String    @unique
  password             String
  assignedToFirstName  String?
  assignedToLastName   String?
  assignedAt           DateTime?
  claimedBy            String?

  @@index([assignedToFirstName, assignedToLastName])
  @@index([assignedAt])
  @@index([claimedBy])
}
